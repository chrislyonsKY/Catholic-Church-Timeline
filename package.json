{
  "name": "catholic-church-timeline",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --base=/Catholic-Church-Timeline/",
    "preview": "vite preview",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run test && npm run build",
    "build:lectionary-reference": "node scripts/build-lectionary-reference.mjs",
    "build:liturgical-calendars": "node scripts/build-liturgical-calendars.mjs",
    "prepare:pages": "npm run test && npm run build:pages && node scripts/publish-pages.mjs",
    "verify:pages": "npm run prepare:pages && node scripts/verify-pages.mjs"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "openseadragon": "^6.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@romcal/calendar.united-states": "3.0.0-dev.125",
    "@tailwindcss/vite": "4.2.1",
    "@types/leaflet": "1.9.21",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "romcal": "3.0.0-dev.125",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.6"
  }
}
